{
  "version": 2,
  "public": false,
  "github": {
    "enabled": true
  },
  "buildCommand": "NEXT_PUBLIC_MOCK_UI=true TURBOPACK=0 next build",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
