# =============================================================================
# VendCFO — Required Environment Variables
# Copy to .env.local and fill in real values
# =============================================================================

# Supabase Auth (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (required)
DATABASE_PRIMARY_URL=postgres://postgres.your-project:password@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Encryption (required — generate with: openssl rand -hex 32)
MIDDAY_ENCRYPTION_KEY=generate-a-64-char-hex-string
FILE_KEY_SECRET=generate-a-64-char-hex-string
